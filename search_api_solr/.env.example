# ── Solr ─────────────────────────────────────────────────────────────────────
SOLR_BASE_URL=https://solrslave-sec.labocleo.org/solr/documents

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8007
API_RELOAD=True
ENVIRONMENT=development

# Types de documents nécessitant des parents (JSON)
TYPES_NEEDING_PARENTS=["article", "chapter"]

# Champs par défaut à retourner (JSON)
DEFAULT_FIELDS=["id", "url", "title", "idparent", "container_url"]

# Auth API externe (permissions)
AUTH_API_URL=https://auth.openedition.org/auth_by_url/

# Mode développement
DEV=true
TEST_IP=139.124.244.81

# Niveau de logs
LOG_LEVEL=DEBUG

# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://search_user:search_password@postgres:5432/search_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_TTL_SEARCH=300
REDIS_TTL_SUGGEST=3600
REDIS_TTL_PERMISSIONS=1800

# ── JWT ───────────────────────────────────────────────────────────────────────
# Changer en production — clé longue et aléatoire (ex: openssl rand -hex 32)
SECRET_KEY=your-secret-key-for-development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# URL frontend utilisée pour les redirections SSO callback
FRONTEND_URL=http://localhost:3003

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Accept,Accept-Language,Authorization,Content-Language,Content-Type,X-Requested-With,X-CSRF-Token
CORS_EXPOSE_HEADERS=X-Total-Count,X-Pagination
CORS_MAX_AGE=86400

# ── LDAP (désactivé par défaut) ───────────────────────────────────────────────
LDAP_ENABLED=false
LDAP_URL=ldaps://ldap.example.org:636
LDAP_BASE_DN=dc=example,dc=org
LDAP_BIND_DN=cn=service,dc=example,dc=org
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(uid={username})
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
# Stratégie si un email LDAP correspond à un compte local existant : reject | merge
LDAP_EMAIL_CONFLICT_STRATEGY=reject

# ── SSO OIDC (désactivé par défaut) ──────────────────────────────────────────
SSO_OIDC_ENABLED=false
SSO_OIDC_ISSUER=https://sso.example.org
SSO_OIDC_CLIENT_ID=openedition-search
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=http://localhost:8003/auth/sso/callback
SSO_OIDC_SCOPES=openid email profile
