# Configuration pour l'environnement de test
# Ce fichier est utilisé lorsque ENVIRONMENT=test

# Environnement
ENVIRONMENT=test

# Configuration Solr (peut utiliser une instance de test)
SOLR_BASE_URL=https://solr-test.openedition.org/solr/documents

# Configuration de l'API
API_HOST=0.0.0.0
API_PORT=8007
API_RELOAD=false

# Configuration CORS pour les tests - minimale
CORS_ORIGINS=http://localhost:8007,http://localhost:3009,http://127.0.0.1:3009,http://127.0.0.1:8007
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST
CORS_ALLOW_HEADERS=Accept,Accept-Language,Content-Type
CORS_EXPOSE_HEADERS=
CORS_MAX_AGE=60

# Dev mode - false pour les tests
DEV=false
TEST_IP=193.48.45.2

# Logging - niveau WARNING pour les tests
LOG_LEVEL=WARNING

# Auth API (peut utiliser un mock)
AUTH_API_URL=http://auth-test.openedition.org/auth_by_url/

# Types de documents nécessitant des parents
types_needing_parents=article,chapter

# Champs par défaut à retourner
default_fields=id,url,title,idparent,container_url