ENVIRONMENT=development
SOLR_BASE_URL=https://solrslave-sec.labocleo.org/solr/documents
API_HOST=0.0.0.0
API_PORT=8007
API_RELOAD=true
# Ports actifs : 3003 (frontend hôte), 3000 (frontend container interne)
# Ports 3007/3009 supprimés (legacy, projet précédent)
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003,http://0.0.0.0:3003
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Accept,Accept-Language,Authorization,Content-Language,Content-Type,X-Requested-With,X-CSRF-Token
CORS_EXPOSE_HEADERS=X-Total-Count,X-Pagination
CORS_MAX_AGE=86400
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEV=true
TEST_IP=139.124.244.81
LOG_LEVEL=DEBUG
AUTH_API_URL=https://auth.openedition.org/auth_by_url/
types_needing_parents=article,chapter
