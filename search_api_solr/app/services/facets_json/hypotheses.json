{
  "platform": {
    "": {
      "name": "platform",
      "type": "match",
      "list": ["platformID"]
    }
  },
  "translations": {
    "": {
      "name": "translations",
      "type": "match",
      "list": ["autodetect_lang"]
    }
  },
  "author": {
    "": {
      "name": "author",
      "type": "match",
      "list": ["contributeurFacet_auteur"]
    }
  },
  "hypotheses-publication": {
    "": {
      "name": "hypotheses-publication",
      "type": "match",
      "list": ["site_title"]
    }
  },
  "date": {
    "": {
      "name": "date",
      "type": "date",
      "list": ["anneedatepubli"],
      "options": {
        "format": "Y"
      }
    }
  },
  "subscribers": {
    "": {
      "name": "subscribers",
      "type": "match",
      "list": ["subscribers"]
    }
  }
