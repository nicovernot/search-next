# Exemple de configuration pour le projet SearchV2
# Copiez ce fichier en .env.shared et .env.development/.env.production
# puis personnalisez les valeurs

# ============================================
# VARIABLES COMMUNES (.env.shared)
# ============================================

# Configuration générale
NODE_ENV=development

# URLs de base
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Configuration Solr
SOLR_URL=http://solr:8983/solr
SOLR_COLLECTION=searchv2

# Configuration CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Configuration de logging
LOG_LEVEL=debug

# ============================================
# VARIABLES SPÉCIFIQUES (.env.development)
# ============================================

# Développement frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_DEBUG=true
REACT_APP_MOCK_API=false

# Développement backend
DEBUG=true
AUTO_RELOAD=true

# Configuration Solr pour dev
SOLR_URL=http://localhost:8983/solr
SOLR_COLLECTION=searchv2_dev

# ============================================
# VARIABLES DE PRODUCTION (.env.production)
# ============================================

# Production frontend
REACT_APP_API_URL=https://api.votre-domaine.com
REACT_APP_DEBUG=false

# Production backend
DEBUG=false
AUTO_RELOAD=false

# Sécurité (à changer absolument!)
JWT_SECRET=votre_secret_jwt_secure
SESSION_SECRET=votre_secret_session_secure

# Performance
WORKER_COUNT=4
CACHE_TTL=3600