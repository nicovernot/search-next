# Variables partagées pour un setup local simple

ENVIRONMENT=development

# Ports exposés par docker-compose
API_PORT=8003
FRONTEND_PORT=3003
POSTGRES_PORT=5435
REDIS_PORT=6376

# Services
NEXT_PUBLIC_API_URL=http://localhost:8003
API_BASE_URL=http://localhost:8003
FRONTEND_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003,http://0.0.0.0:3000,http://0.0.0.0:3003,http://localhost:8003

# Solr distant
SOLR_BASE_URL=https://solrslave-sec.labocleo.org/solr/documents

# Base de données / cache
DATABASE_URL=postgresql://search_user:search_password@postgres:5432/search_db
REDIS_URL=redis://redis:6379/0

# Sécurité locale
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Authentification LDAP (désactivée par défaut)
LDAP_ENABLED=false
LDAP_URL=ldaps://ldap.example.org:636
LDAP_BASE_DN=dc=example,dc=org
LDAP_BIND_DN=cn=service,dc=example,dc=org
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(uid={username})
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
LDAP_EMAIL_CONFLICT_STRATEGY=reject

# Authentification SSO OIDC (désactivée par défaut)
SSO_OIDC_ENABLED=false
SSO_OIDC_ISSUER=https://sso.example.org
SSO_OIDC_CLIENT_ID=openedition-search
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=http://localhost:8003/auth/sso/callback
SSO_OIDC_SCOPES=openid email profile
