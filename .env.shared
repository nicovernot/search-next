# Variables communes à tous les environnements et services
# Ce fichier est chargé par tous les services et peut être surchargé par les .env locaux

# Configuration générale
NODE_ENV=development

# URLs de base (surchargeable par environnement)
# API_BASE_URL : port HÔTE du proxy Docker (8003 → container:8007)
# Pour dev sans Docker (uvicorn direct), surcharger dans .env.local : API_BASE_URL=http://localhost:8007
API_BASE_URL=http://localhost:8003
FRONTEND_URL=http://localhost:3003

# Configuration Solr commune
SOLR_URL=http://solr:8983/solr
SOLR_COLLECTION=searchv2

# Configuration CORS
# CORS_ORIGINS est le nom lu par le backend FastAPI (settings.py: os.getenv("CORS_ORIGINS")).
# Il doit contenir les origines du navigateur, y compris 0.0.0.0 quand le frontend Docker
# est ouvert via http://0.0.0.0:3003.
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://127.0.0.1:3000,http://127.0.0.1:3003,http://0.0.0.0:3000,http://0.0.0.0:3003,http://localhost:8003

# Configuration de logging
LOG_LEVEL=debug

# Configuration Redis
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_TTL_SEARCH=300
REDIS_TTL_SUGGEST=3600
REDIS_TTL_PERMISSIONS=1800

# Variables pour les tests
TEST_TIMEOUT=30000
TEST_RETRIES=3
