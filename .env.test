# Variables spécifiques à l'environnement de test
# Surcharge les valeurs du .env.shared
ENVIRONMENT=test
NODE_ENV=test

# Test frontend
NEXT_PUBLIC_API_URL=http://localhost:8007
REACT_APP_DEBUG=true
REACT_APP_MOCK_API=true

# Test backend
DEBUG=true
AUTO_RELOAD=false

# Configuration Solr pour les tests
SOLR_URL=http://solr-test:8983/solr
SOLR_COLLECTION=searchv2_test

# Désactive l'authentification pour les tests
DISABLE_AUTH=true

# Configuration spécifique aux tests
TEST_DATABASE_URL=sqlite:///:memory:
TEST_TIMEOUT=10000
TEST_RETRIES=2

# Désactive les limites de taux pour les tests
RATE_LIMIT=10000
