# Fichier d'exemple pour la configuration frontend
# Copiez ce fichier en .env et ajustez selon votre environnement

# Environnement (development, staging, production, test)
ENVIRONMENT=development

# URL de l'API backend
# - development: http://localhost:8007
# - staging: https://api-staging.search.openedition.org
# - production: https://api.search.openedition.org
# - test: http://localhost:8007
REACT_APP_API_URL=http://localhost:8007

# Ports
# - FRONTEND_PORT: Port exposé sur la machine hôte (3009 pour dev, 80 pour prod)
# - PORT: Port interne du serveur de développement (3000)
FRONTEND_PORT=3009
PORT=3000

# Clé API SearchKit (optionnelle)
REACT_APP_SEARCHKIT_API_KEY=

# Variables React
# - development: development
# - production: production
NODE_ENV=development

# Configuration du proxy (optionnel)
PROXY_API=http://localhost:8007

# Pour plus de détails, voir la documentation complète