# Configuration pour l'environnement de test frontend
# Ce fichier est utilisé lorsque ENVIRONMENT=test

# Environnement
ENVIRONMENT=test

# URL de l'API backend (test)
REACT_APP_API_URL=http://localhost:8007

# Ports
FRONTEND_PORT=3009
PORT=3000

# Configuration pour les tests
REACT_APP_SEARCHKIT_API_KEY=test_key

# Variables pour les tests
NODE_ENV=test
CI=true

# Configuration du proxy (optionnel)
PROXY_API=http://localhost:8007

# Configuration pour les tests
BROWSER=none
WATCH=false